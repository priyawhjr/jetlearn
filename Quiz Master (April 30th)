# func to open a file & read its ques from a file 
def read_question_file():
    global question_count, questions
    q_file = open(question_file_name, "r") # open file in read mode only
    for question in q_file: #'question' variable declared at last
       
        questions.append(question)# it appends question to questions list.
        question_count += 1 #keeps track of tot. num. of ques in the file.
    q_file.close() #close file after reading all Q.

# func to read next ques
def read_next_ques():
    global question_index
    question_index +=  1
    #The first question that has been added to the 
    # questions list is obtained and split using ‘|’ as the separator
    # to split the Q & ans from '|' for ans_boxes 
    return questions.pop(0).split("|") #'questions' is list declared above

   
'''It checks if the click is inside any of the answer choice boxes.
If the correct answer box is clicked, correct_answer() is called.
If a wrong answer box is clicked, game_over() is called.'''
def on_mouse_down(pos):#'on_mouse_down()' handles mouse clicks
    index = 1 #variable 'index' to track of the current ans_box being chckd
    for box in answer_boxes:#Iterates each 'box' in list 'answer_boxes'
        if box.collidepoint(pos):#mouse click 'pos' is inside the current answer box
            if index == int(question[5]): #question[5] is- index of correct answer for the current question.
                correct_answer()#If correct,calls the correct_answer()
            else:
                game_over()#If incorrect, it calls the game_over function.
        index = index + 1
    #It also checks if the mouse click happened inside the skip box, 
        #in that case it calls the skip_question().
    if skip_box.collidepoint(pos):
        skip_question()


def correct_answer(): #declare correct_answer()
    global score, question, time_left, questions
    score = score + 1
    if questions: #If more questions left (i.e more ques ==True),
        question = read_next_ques()# it fetches next question using read_next_question()
        time_left = 10 # & resets the time_left= 10.
    else:
        game_over()#If no more questions left, it calls game_over() 

def game_over():
    global question, time_left, is_game_over
    message = f"Game over!\nYou got {score} questions correct!"
    #question = [msssage, option1, option2, option3, option4, correct_answer]
    question = [message, "-","-","-","-",5] # to show game over message in ques_box
       #OR
    #question = [message, " ", " ", " ", " ", 5]
    time_left = 0
    is_game_over = True


def skip_question():
    global question, time_left
    #It checks if there are more questions and the game is not over.
    if questions and not is_game_over:
        question = read_next_ques()#fetches the next question using read_next_question()
        time_left = 10 # and resets time_left to 10.
    else:
        game_over()#If no more questions left or the game is over,calls game_over


def update_time_left():
    global time_left
    if time_left: # if true
        time_left = time_left - 1
    else:
        game_over()


